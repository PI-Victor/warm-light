{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WarmLight",
  "version": "0.1.0",
  "identifier": "dev.warmlight.app",
  "build": {
    "beforeBuildCommand": "trunk build",
    "beforeDevCommand": "trunk serve --address 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "WarmLight",
        "width": 1180,
        "height": 840,
        "minWidth": 920,
        "minHeight": 680,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
